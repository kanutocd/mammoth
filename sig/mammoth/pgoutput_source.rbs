module Mammoth
  # Streams PostgreSQL logical replication through the CDC Ecosystem boundary.
  class PgoutputSource
    @config: Mammoth::Configuration
    @runner: untyped
    @parser: untyped
    @decoder: untyped
    @source_adapter: untyped
    @effective_runner: untyped
    @effective_parser: untyped
    @effective_decoder: untyped
    @effective_source_adapter: untyped

    attr_reader config: Mammoth::Configuration
    attr_reader runner: untyped
    attr_reader parser: untyped
    attr_reader decoder: untyped
    attr_reader source_adapter: untyped

    def initialize: (Mammoth::Configuration config, ?runner: untyped, ?parser: untyped, ?decoder: untyped, ?source_adapter: untyped) -> void

    def each: () ?{ (untyped work) -> untyped } -> (Enumerator[untyped, nil] | nil)

    private

    def normalized_items: (untyped payload, untyped metadata) -> Array[untyped]
    def parsed_payload: (untyped payload) -> untyped
    def normalize_source_positions: (Array[untyped] items) -> Array[untyped]
    def invoke_source_adapter: (untyped decoded, untyped metadata) -> untyped
    def invoke_component: (untyped component, *untyped args) -> untyped
    def effective_runner: () -> untyped
    def effective_parser: () -> untyped
    def effective_decoder: () -> untyped
    def effective_source_adapter: () -> untyped
    def build_runner: () -> untyped
    def build_parser: () -> untyped
    def build_decoder: () -> untyped
    def build_source_adapter: () -> untyped
    def database_url: () -> String
    def require_optional!: (String feature, String gem_name) -> bool
    def require_any!: (Array[String] features, String gem_name) -> bool
    def constant_or_nil: (String name) -> untyped
  end
end
