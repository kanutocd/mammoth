module Mammoth
  module OperationalState
    # Registry for operational state adapters.
    module Registry
      def self.register: (untyped name, untyped adapter) -> untyped
      def self.fetch: (untyped name) -> untyped
      def self.build: (untyped name, untyped config) -> untyped
      def self.build_configured: (untyped config) -> untyped
      def self.names: () -> untyped
      def self.registry: () -> untyped
    end
  end
end
