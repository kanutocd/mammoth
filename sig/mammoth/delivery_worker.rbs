module Mammoth
  # Delivers normalized events with retry, checkpoint, and dead-letter handling.
  #
  # DeliveryWorker is Mammoth's first reliable delivery unit. It intentionally keeps
  # the delivery contract small: attempt webhook delivery, advance the checkpoint
  # after success, and persist the failed event to the dead letter queue after
  # retry exhaustion.
  class DeliveryWorker
    @sink: untyped

    @checkpoint_store: untyped

    @dead_letter_store: untyped

    @delivered_envelope_store: untyped

    @source_name: untyped

    @slot_name: untyped

    @publication_name: untyped

    @max_attempts: untyped

    @retry_schedule: untyped

    @sleeper: untyped

    @route_filter: untyped

    @payload_policy: untyped

    @enabled: untyped
    @logger: untyped

    DEFAULT_SOURCE: "postgresql"

    attr_reader sink: untyped

    attr_reader checkpoint_store: untyped

    attr_reader dead_letter_store: untyped

    attr_reader delivered_envelope_store: untyped

    attr_reader retry_schedule: untyped

    attr_reader max_attempts: untyped

    attr_reader sleeper: untyped

    attr_reader source_name: untyped

    attr_reader slot_name: untyped

    attr_reader publication_name: untyped

    attr_reader route_filter: untyped

    attr_reader payload_policy: untyped

    attr_reader enabled: untyped
    attr_reader logger: untyped

    # @param sink [#deliver] destination sink
    # @param checkpoint_store [Mammoth::CheckpointStore] checkpoint persistence
    # @param dead_letter_store [Mammoth::DeadLetterStore] dead letter persistence
    # @param source_name [String] logical source name
    # @param slot_name [String] replication slot name
    # @param publication_name [String] publication name
    # @param max_attempts [Integer] maximum delivery attempts
    # @param retry_schedule [Array<Integer>] retry wait schedule in seconds
    # @param sleeper [#call] sleep strategy, injectable for tests
    def initialize: (sink: untyped, checkpoint_store: untyped, dead_letter_store: untyped, delivered_envelope_store: untyped, source_name: untyped, slot_name: untyped, publication_name: untyped, max_attempts: untyped, retry_schedule: untyped, ?sleeper: untyped, ?route_filter: untyped, ?payload_policy: untyped, ?enabled: untyped, ?logger: untyped) -> void

    # Build a delivery worker from Mammoth configuration and stores.
    #
    # @param config [Mammoth::Configuration] loaded configuration
    # @param sink [#deliver] destination sink
    # @param checkpoint_store [Mammoth::CheckpointStore] checkpoint persistence
    # @param dead_letter_store [Mammoth::DeadLetterStore] dead letter persistence
    # @param sleeper [#call] sleep strategy
    # @return [Mammoth::DeliveryWorker]
    def self.from_config: (untyped config, sink: untyped, checkpoint_store: untyped, dead_letter_store: untyped, delivered_envelope_store: untyped, ?sleeper: untyped, ?delivery_policy: untyped, ?logger: untyped) -> untyped

    # Deliver an event with retry, checkpoint, and DLQ handling.
    #
    # @param event [CDC::Core::ChangeEvent] normalized event
    # @return [Hash] delivery summary
    def deliver_transaction: (CDC::Core::TransactionEnvelope envelope) -> untyped

    def deliver: (CDC::Core::ChangeEvent event) -> untyped

    def deliver_payload: (Hash[String, untyped] payload) -> untyped

    private

    def deliver_work: (untyped work, serializer: untyped, delivery_method: untyped) -> untyped

    def deliver_prepared: (untyped prepared, work: untyped?, delivery_method: untyped) -> untyped

    def idempotency_key_for: (payload: untyped, delivery_unit: untyped) -> String

    def delivery_unit_for: (untyped delivery_method) -> Symbol

    def destination_name: () -> untyped

    def skip_result_for: (untyped payload, idempotency_key: untyped) -> untyped

    def skipped: (untyped payload, idempotency_key: untyped, reason: untyped) -> untyped

    def deliver_to_sink: (untyped prepared, work: untyped?, delivery_method: untyped) -> untyped

    def dead_letter: (untyped payload, untyped error, untyped attempts) -> { status: "dead_lettered", dead_letter_id: untyped, attempts: untyped }

    def wait_before_retry: (untyped attempts) -> untyped

    def transaction_payload?: (untyped payload) -> bool
    def log_outcome: (untyped event, untyped result, delivery_unit: untyped) -> untyped
  end
end
