module Mammoth
  # Consumes normalized CDC work from an injected source.
  class ReplicationConsumer
    @source: untyped

    @delivery_unit: untyped

    attr_reader source: untyped

    attr_reader delivery_unit: untyped

    def initialize: (?source: untyped, ?delivery_unit: untyped) -> void

    def start: () ?{ ((CDC::Core::ChangeEvent | CDC::Core::TransactionEnvelope) event) -> untyped } -> (Integer | Enumerator[untyped, Integer])

    private

    def each_event: () { (untyped event) -> untyped } -> untyped
    def effective_source: () -> untyped
    def flatten_cdc_work: (untyped work) -> Array[untyped]
    def transaction_delivery?: () -> bool
    def transaction_work: (CDC::Core::TransactionEnvelope envelope) -> Array[untyped]
    def event_work: (CDC::Core::ChangeEvent event) -> Array[untyped]
    def transaction_envelope: (CDC::Core::ChangeEvent event) -> CDC::Core::TransactionEnvelope
  end
end
