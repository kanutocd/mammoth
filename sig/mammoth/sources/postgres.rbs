module Mammoth
  module Sources
    # Concrete PostgreSQL CDC source for Mammoth.
    class Postgres
      @config: Mammoth::Configuration
      @runner: untyped
      @parser: untyped
      @decoder: untyped
      @adapter: untyped
      @effective_runner: untyped
      @effective_parser: untyped
      @effective_decoder: untyped
      @effective_adapter: untyped
      @transaction_events: Array[untyped]?
      @transaction_id: untyped
      @transaction_metadata: Hash[untyped, untyped]?

      attr_reader config: Mammoth::Configuration
      attr_reader runner: untyped
      attr_reader parser: untyped
      attr_reader decoder: untyped
      attr_reader adapter: untyped

      def initialize: (Mammoth::Configuration config, ?runner: untyped, ?parser: untyped, ?decoder: untyped, ?adapter: untyped) -> void

      def each: () ?{ (untyped work) -> untyped } -> (Enumerator[untyped, nil] | nil)

      private

      def process_payload: (untyped payload, untyped metadata) { (untyped work) -> untyped } -> untyped
      def process_decoded: (untyped decoded, untyped metadata) { (untyped work) -> untyped } -> untyped
      def parse_payload: (untyped payload) -> untyped
      def decode_message: (untyped message, untyped metadata) -> untyped
      def normalize_decoded: (untyped decoded) -> Array[untyped]
      def begin_message?: (untyped decoded) -> bool
      def commit_message?: (untyped decoded) -> bool
      def message_kind: (untyped decoded) -> String
      def start_transaction_buffer: (untyped decoded) -> void
      def emit_transaction_buffer: (untyped decoded, untyped metadata) { (untyped work) -> untyped } -> void
      def transaction_id_for: (untyped decoded) -> untyped
      def commit_lsn_for: (untyped decoded, untyped metadata) -> untyped
      def transaction_buffer_active?: () -> bool
      def clear_transaction_buffer: () -> void
      def enrich_work_position: (untyped work, untyped metadata, untyped decoded) -> untyped
      def first_event_value: (*Symbol keys) -> untyped
      def value_from: (untyped object, *Symbol keys) -> untyped
      def value_hash: (untyped object, Symbol key) -> Hash[untyped, untyped]?
      def effective_runner: () -> untyped
      def effective_parser: () -> untyped
      def effective_decoder: () -> untyped
      def effective_adapter: () -> untyped
      def build_runner: () -> untyped
      def runner_options: () -> Hash[Symbol, untyped]
      def build_parser: () -> untyped
      def build_decoder: () -> untyped
      def build_adapter: () -> untyped
      def required_publications: () -> Array[String]
      def database_url: () -> String
      def callable_accepts_metadata?: (untyped object, Symbol method_name) -> bool
      def required_config: (*String keys) -> untyped
      def require_optional!: (String feature, String gem_name) -> bool

      TransactionEnvelope: singleton(::Data)
    end
  end
end
