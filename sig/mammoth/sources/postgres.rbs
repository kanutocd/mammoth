module Mammoth
  module Sources
    # Concrete PostgreSQL CDC source for Mammoth.
    class Postgres
      @config: Mammoth::Configuration
      @runner: untyped
      @parser: untyped
      @decoder: untyped
      @adapter: untyped
      @checkpoint_store: untyped
      @publication_inspector: untyped
      @logger: untyped
      @effective_runner: untyped
      @effective_parser: untyped
      @effective_decoder: untyped
      @effective_adapter: untyped
      @effective_publication_inspector: untyped
      @publication_tables: Array[PostgresPublicationTable]?
      attr_reader config: Mammoth::Configuration
      attr_reader runner: untyped
      attr_reader parser: untyped
      attr_reader decoder: untyped
      attr_reader adapter: untyped
      attr_reader checkpoint_store: untyped
      attr_reader publication_inspector: untyped
      attr_reader logger: untyped

      def initialize: (Mammoth::Configuration config, ?runner: untyped, ?parser: untyped, ?decoder: untyped, ?adapter: untyped, ?checkpoint_store: untyped, ?publication_inspector: untyped, ?logger: untyped) -> void

      def each: () ?{ ((CDC::Core::ChangeEvent | CDC::Core::TransactionEnvelope) work) -> untyped } -> (Enumerator[(CDC::Core::ChangeEvent | CDC::Core::TransactionEnvelope), nil] | nil)
      def acknowledge: (untyped lsn) -> untyped
      def progress_position_for: (untyped work) -> untyped
      def slot_health: () -> PostgresSlotHealth

      private

      def decoded_stream: () -> Enumerator[untyped, nil]
      def process_payload: (untyped payload, untyped metadata) { (untyped work) -> untyped } -> untyped
      def each_decoded: (untyped decoded) { (untyped work) -> untyped } -> untyped
      def stream_event: (untyped decoded, untyped metadata) -> untyped
      def yield_with_progress_position: (untyped work) { (untyped work) -> untyped } -> untyped
      def validate_core_work!: (untyped work) -> (CDC::Core::ChangeEvent | CDC::Core::TransactionEnvelope)
      def parse_payload: (untyped payload) -> untyped
      def decode_message: (untyped message, untyped metadata) -> untyped
      def value_from: (untyped object, *Symbol keys) -> untyped
      def source_position: (untyped metadata) -> untyped
      def acknowledgement_position: (untyped metadata) -> untyped
      def yielded_work_includes?: (untyped work) -> bool
      def effective_runner: () -> untyped
      def effective_parser: () -> untyped
      def effective_decoder: () -> untyped
      def effective_adapter: () -> untyped
      def effective_publication_inspector: () -> untyped
      def build_runner: () -> untyped
      def runner_options: () -> Hash[Symbol, untyped]
      def build_parser: () -> untyped
      def build_decoder: () -> untyped
      def build_adapter: () -> untyped
      def build_publication_inspector: () -> PostgresPublicationInspector
      def replication_start_lsn: () -> untyped
      def preflight_slot!: () -> nil
      def preflight_replica_identity!: () -> nil
      def publication_tables: () -> Array[PostgresPublicationTable]
      def replica_identity_relations: () -> Hash[(Integer | [String, String]), Array[String]]
      def inspected_slot_status: () -> untyped
      def validate_temporary_slot_resume!: (untyped resume_lsn) -> untyped
      def validate_slot_identity!: (untyped status) -> untyped
      def validate_slot_health!: (untyped status) -> untyped
      def validate_slot_reachability!: (untyped status, untyped resume_lsn) -> untyped
      def parse_transport_lsn: (untyped value, String label) -> Integer
      def metric_lsn: (untyped value) -> Integer?
      def replica_identity_name: (untyped value) -> untyped
      def safe_auto_create_slot?: () -> bool
      def missing_slot_message: (untyped resume_lsn) -> String
      def checkpoint_lsn: () -> untyped
      def source_name: () -> untyped
      def normalize_lsn: (untyped value) -> untyped
      def blank?: (untyped value) -> bool
      def required_publications: () -> Array[String]
      def database_url: () -> String
      def callable_accepts_metadata?: (untyped object, Symbol method_name) -> bool
      def required_config: (*String keys) -> untyped
      def require_optional!: (String feature, String gem_name) -> bool
    end
  end
end
