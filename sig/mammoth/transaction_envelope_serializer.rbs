module Mammoth
  # Serializes CDC transaction envelopes into webhook payloads.
  class TransactionEnvelopeSerializer
    @envelope: untyped
    @envelope_metadata: untyped

    PAYLOAD_TYPE: "transaction.committed"

    attr_reader envelope: untyped

    def self.call: (CDC::Core::TransactionEnvelope envelope) -> Hash[String, untyped]
    def initialize: (CDC::Core::TransactionEnvelope envelope) -> void
    def call: () -> Hash[String, untyped]
    def to_json: (*untyped _args) -> String

    private

    def stringify_keys: (untyped hash) -> Hash[String, untyped]
    def envelope_metadata: () -> Hash[String, untyped]
    def deterministic_event_id: (Array[Hash[String, untyped]] event_payloads) -> String
    def source_position: (Array[Hash[String, untyped]] event_payloads) -> untyped
    def committed_at: () -> untyped
    def first_event_value: (Array[Hash[String, untyped]] event_payloads, untyped key) -> untyped
  end
end
