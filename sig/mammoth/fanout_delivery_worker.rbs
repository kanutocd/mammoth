module Mammoth
  # Delivers one CDC work item to multiple destination-specific workers.
  class FanoutDeliveryWorker
    @delivery_workers: untyped

    attr_reader delivery_workers: untyped

    # @param delivery_workers [Array<Mammoth::DeliveryWorker>] destination workers
    def initialize: (untyped delivery_workers) -> void

    # Deliver an event to every configured destination.
    #
    # @param event [CDC::Core::ChangeEvent] normalized event
    # @return [Hash] aggregate fanout summary
    def deliver: (CDC::Core::ChangeEvent event) -> untyped

    # Deliver a transaction envelope to every configured destination.
    #
    # @param envelope [CDC::Core::TransactionEnvelope] CDC transaction envelope
    # @return [Hash] aggregate fanout summary
    def deliver_transaction: (CDC::Core::TransactionEnvelope envelope) -> untyped

    # Deliver an event to one configured destination.
    #
    # @param destination_name [String] destination name
    # @param event [CDC::Core::ChangeEvent] normalized event
    # @return [Hash] destination delivery summary
    def deliver_to: (String destination_name, CDC::Core::ChangeEvent event) -> untyped

    # Deliver a transaction envelope to one configured destination.
    #
    # @param destination_name [String] destination name
    # @param envelope [CDC::Core::TransactionEnvelope] CDC transaction envelope
    # @return [Hash] destination delivery summary
    def deliver_transaction_to: (String destination_name, CDC::Core::TransactionEnvelope envelope) -> untyped

    def deliver_payload_to: (String destination_name, Hash[String, untyped] payload) -> untyped

    private

    def fanout: (untyped delivery_method, untyped work) -> untyped

    def aggregate_status: (untyped results) -> String

    def worker_for: (String destination_name) -> untyped
  end
end
