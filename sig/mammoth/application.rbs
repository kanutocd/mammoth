module Mammoth
  # Top-level Mammoth application runtime.
  #
  # Application wires Mammoth's delivery-side runtime pieces: configuration,
  # SQLite operational memory, replication consumer, delivery worker, checkpoint
  # store, dead letter store, and webhook sink. Upstream PostgreSQL transport
  # composition stays outside this class so the application runtime consumes an
  # injected CDC work source rather than owning upstream CDC source-adapter
  # lifecycle decisions.
  class Application
    @config: untyped

    @state_adapter: untyped

    @consumer: untyped

    @delivery_worker: untyped

    @runtime: untyped

    @checkpoint_store: untyped

    @lifecycle_hooks: untyped

    attr_reader config: untyped

    attr_reader state_adapter: untyped

    attr_reader consumer: untyped

    attr_reader delivery_worker: untyped
    attr_reader checkpoint_store: untyped
    attr_reader lifecycle_hooks: untyped

    def sqlite_store: () -> untyped

    # @param config [Mammoth::Configuration] loaded configuration
    # @param source [#each, nil] injectable event source for tests and demos
    # @param sink [#deliver, nil] optional destination sink
    # @param sleeper [#call] retry sleep strategy
    # @param lifecycle_hooks [Mammoth::LifecycleHooks, Hash] local lifecycle callbacks
    def initialize: (untyped config, ?source: untyped?, ?sink: untyped?, ?state_adapter: untyped?, ?sleeper: untyped, ?lifecycle_hooks: untyped) -> void

    # Start the application runtime and deliver consumed events.
    #
    # @return [Integer] number of processed events
    def start: () -> untyped

    private

    def build_lifecycle_hooks: (untyped hooks) -> untyped

    def application_context: (?untyped extra) -> untyped

    def process_consumer: (untyped runtime) -> untyped

    def flush_batch: (untyped runtime, untyped batch) -> untyped

    def process_work: (untyped runtime, untyped work) -> untyped

    def process_batch: (untyped runtime, untyped batch) -> untyped

    def runtime_batching?: (untyped runtime) -> bool

    def build_runtime: () -> untyped

    def build_source: () -> untyped
    def build_delivery_worker: (sink: untyped, sleeper: untyped, ?delivery_policy: untyped) -> untyped
    def build_configured_delivery_worker: (sleeper: untyped) -> untyped
    def destination_specs: () -> untyped

    def destination_delivery_policy: (untyped destination) -> untyped

    def build_state_adapter: () -> untyped

    def delivery_unit: () -> Symbol

    def runtime_adapter: () -> untyped

    def runtime_concurrency: () -> untyped

    def runtime_timeout: () -> untyped

    def runtime_batch_size: () -> untyped

    def runtime_preserve_order?: () -> bool
  end
end
