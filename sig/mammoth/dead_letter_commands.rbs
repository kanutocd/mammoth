module Mammoth
  # Operator commands for inspecting and replaying dead letters.
  class DeadLetterCommands
    @argv: untyped

    @lifecycle_hooks: untyped

    @state_adapter: untyped

    attr_reader argv: untyped
    attr_reader lifecycle_hooks: untyped

    # @param argv [Array<String>] command line arguments
    def self.call: (untyped argv, ?state_adapter: untyped?, ?lifecycle_hooks: untyped) -> untyped

    # @param argv [Array<String>] command line arguments
    # @param lifecycle_hooks [Mammoth::LifecycleHooks, Hash] local lifecycle callbacks
    def initialize: (untyped argv, ?state_adapter: untyped?, ?lifecycle_hooks: untyped) -> void

    # Dispatch the nested dead-letter subcommand.
    #
    # @return [Integer] process status code
    def call: () -> untyped

    private

    def command: () -> untyped

    def config_path: () -> untyped

    def list: () -> untyped

    def show: () -> untyped

    def replay: () -> untyped

    def load_config: () -> untyped

    def dead_letter_store: () -> untyped

    def state_adapter: () -> untyped

    def worker: () -> untyped

    def dead_letter_id: () -> untyped

    def list_options: () -> untyped

    def parse_list_option: (untyped args, untyped index, untyped options) -> untyped
    def assign_option: (untyped args, untyped index, untyped options, untyped key) -> untyped
    def assign_time_option: (untyped args, untyped index, untyped options, untyped key) -> untyped
    def assign_limit_option: (untyped args, untyped index, untyped options) -> untyped
    def parse_limit_option: (untyped value) -> untyped

    def replay_rows: () -> untyped
    def replay_options: () -> untyped
    def parse_replay_option: (untyped args, untyped index, untyped options) -> untyped
    def parse_time_option: (untyped value, untyped option_name) -> untyped

    def fetch_dead_letter!: (untyped id) -> untyped

    def replay_row: (untyped row) -> untyped

    def replay_payload: (untyped destination_name, untyped payload) -> untyped

    def replay_fanout_payload: (untyped destination_name, untyped payload) -> untyped

    def replay_resolved?: (untyped result) -> bool

    def show_payload: (untyped row) -> untyped

    def list_header: () -> String

    def list_row: (untyped row) -> String

    def replay_message: (untyped row, untyped result) -> String

    def replay_context: (?untyped extra) -> untyped
  end
end
