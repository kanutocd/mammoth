module Mammoth
  # Adapter object used by CDC::Concurrent::ProcessorPool.
  class DeliveryProcessor < CDC::Core::Processor
    @delivery_worker: untyped
    @delivery_unit: untyped
    @progress_coordinator: untyped

    attr_reader delivery_worker: untyped
    attr_reader delivery_unit: untyped
    attr_reader progress_coordinator: untyped

    def self.concurrent_safe!: () -> bool
    def self.concurrent_safe?: () -> bool
    def self.concurrent_safe: () -> bool

    def concurrent_safe?: () -> bool
    def concurrent_safe: () -> bool

    def initialize: (delivery_worker: untyped, ?delivery_unit: untyped, ?progress_coordinator: untyped) -> void

    def call: (untyped work) -> CDC::Core::ProcessorResult
    def process: (untyped work) -> CDC::Core::ProcessorResult

    private

    def deliver: (untyped work) -> untyped
    def build_result: (untyped work, untyped summary) -> CDC::Core::ProcessorResult
    def failure_result: (untyped work, StandardError error, retryable: bool, ?summary: untyped?) -> CDC::Core::ProcessorResult
    def failure_reason: (untyped summary) -> String
    def result_metadata: (untyped? summary) -> untyped
  end
end
