module Mammoth
  module Commands
    # Initializes the configured operational SQLite database.
    class BootstrapCommand
      @config: untyped

      @state_adapter: untyped

      @output: untyped

      attr_reader config: untyped

      attr_reader state_adapter: untyped

      attr_reader output: untyped

      # @param config [Mammoth::Configuration] loaded configuration
      # @param output [#puts] output stream
      def initialize: (untyped config, ?state_adapter: untyped?, ?output: untyped) -> void

      # @return [Integer] process-style status code
      def call: () -> Integer
    end
  end
end
