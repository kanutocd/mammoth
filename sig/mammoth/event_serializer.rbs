module Mammoth
  # Serializes CDC-core change events into webhook payloads.
  class EventSerializer
    @event: untyped

    DEFAULT_SOURCE: String

    def self.call: (CDC::Core::ChangeEvent event) -> Hash[String, untyped]
    def initialize: (CDC::Core::ChangeEvent event) -> void
    def call: () -> Hash[String, untyped]
    def to_json: (*untyped _args) -> String

    private

    def stringify_keys: (untyped hash) -> Hash[String, untyped]
    def normalize_operation: (untyped operation) -> String
    def event_id: (Hash[String, untyped] metadata) -> String
    def source: (Hash[String, untyped] metadata) -> String
    def occurred_at: (Hash[String, untyped] event_hash) -> untyped
    def event_data: (Hash[String, untyped] event_hash) -> untyped
  end
end
