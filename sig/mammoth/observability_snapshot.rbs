module Mammoth
  # Builds health, readiness, and metrics snapshots from Mammoth's local
  # operational state.
  class ObservabilitySnapshot
    include ObservabilityMetrics

    @config: untyped

    @state_adapter: untyped

    @clock: untyped
    @dispatch_metrics: DispatchMetrics
    @slot_health_provider: untyped

    attr_reader config: untyped

    attr_reader state_adapter: untyped

    attr_reader clock: untyped
    attr_reader dispatch_metrics: DispatchMetrics
    attr_reader slot_health_provider: untyped

    # @param config [Mammoth::Configuration] loaded configuration
    # @param state_adapter [Mammoth::OperationalState::Adapter, nil] operational state dependency
    # @param clock [#call] time source returning a Time-like object
    def initialize: (untyped config, ?state_adapter: untyped?, ?clock: untyped?, ?dispatch_metrics: DispatchMetrics, ?slot_health_provider: untyped?) -> void

    # Build a liveness response.
    #
    # @return [Hash] health payload
    def health: () -> untyped

    # Build a readiness response.
    #
    # @return [Hash] readiness payload
    def readiness: () -> untyped

    # Build a Prometheus text exposition document.
    #
    # @return [String] Prometheus metrics text
    def prometheus: () -> String

    private

    def aggregate_metric_lines: (checkpoint_store: untyped, dead_letter_store: untyped, delivered_store: untyped) -> untyped

    def destination_metric_lines: (dead_letter_store: untyped, delivered_store: untyped) -> untyped

    def unready_payload: () -> untyped

    def adapter_error_payload: (untyped error) -> untyped
    def postgres_unready_payload: (untyped health) -> untyped
    def postgres_error_payload: (untyped error) -> untyped

    def down_metrics: () -> String
    def postgres_slot_metric_lines: () -> Array[String]
    def postgres_slot_health: () -> untyped

    def state_summary: () -> untyped

    def configured_adapter_name: () -> untyped

    def mammoth_name: () -> untyped

    def destination_names: () -> untyped

    def checked_at: () -> untyped

    def metric_headers: () -> untyped

  end
end
