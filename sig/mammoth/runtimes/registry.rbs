module Mammoth
  module Runtimes
    # Registry for delivery runtime adapters.
    module Registry
      def self.register: (untyped name, untyped adapter) -> untyped
      def self.fetch: (untyped name) -> untyped
      def self.build: (untyped name, ?batch_size: Integer, **untyped options) -> Mammoth::Runtimes::BatchingRuntime
      def self.names: () -> untyped
      def self.registry: () -> untyped
    end
  end
end
