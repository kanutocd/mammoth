module Mammoth
  VERSION: String

  type event = Hash[String, untyped] | Hash[Symbol, untyped] | _ToH
  type row = Hash[String, untyped]

  interface _ToH
    def to_h: () -> Hash[untyped, untyped]
  end

  interface _EventSource
    def each: () { (untyped) -> untyped } -> untyped
  end

  interface _Adapter
    def call: (untyped) -> untyped
  end

  interface _Runner
    def start: () { (String, untyped) -> untyped } -> untyped
  end

  interface _Component
    def call: (*untyped args) -> untyped
  end

  interface _Sleeper
    def call: (Integer | Float) -> untyped
  end

  interface _Sink
    def name: () -> String
    def deliver: (untyped event) -> Hash[Symbol, untyped]
  end

  class Error < StandardError
  end

  class ConfigurationError < Error
  end

  class StoreError < Error
  end

  class DeliveryError < Error
  end

  class ReplicationError < Error
  end

  class Application
    attr_reader config: Configuration
    attr_reader sqlite_store: SQLiteStore
    attr_reader consumer: ReplicationConsumer
    attr_reader delivery_worker: DeliveryWorker

    def initialize: (Configuration config, ?source: _EventSource?, ?adapter: _Adapter?, ?sink: _Sink?, ?sleeper: _Sleeper) -> void
    def start: () -> Integer

    private

    def build_delivery_worker: (sink: _Sink, sleeper: _Sleeper) -> DeliveryWorker
  end

  class CheckpointStore
    attr_reader sqlite_store: SQLiteStore

    def initialize: (SQLiteStore sqlite_store) -> void
    def write: (source_name: String, slot_name: String, publication_name: String, last_lsn: String?) -> row?
    def fetch: (source_name: String, slot_name: String) -> row?
    def count: () -> Integer

    private

    def database: () -> untyped
  end

  class CLI
    USAGE: String

    attr_reader argv: Array[String]

    def self.call: (Array[String] argv) -> Integer
    def initialize: (Array[String] argv) -> void
    def call: () -> Integer

    private

    def command: () -> String?
    def config_path: () -> String?
    def version: () -> Integer
    def validate: () -> Integer
    def bootstrap: () -> Integer
    def status: () -> Integer
    def start: () -> Integer
    def deliver_sample: () -> Integer
    def load_config: () -> Configuration
  end

  class Configuration
    DEFAULT_SCHEMA_PATH: String

    attr_reader path: String
    attr_reader data: Hash[untyped, untyped]?
    attr_reader schema_path: String

    def self.load: (String path, ?schema_path: String) -> Configuration
    def initialize: (String path, ?schema_path: String) -> void
    def load: () -> Configuration
    def dig: (*String keys) -> untyped

    private

    def validate_schema!: () -> void
    def schema_error_message: (Array[String] errors) -> String
  end

  class DeadLetterStore
    attr_reader sqlite_store: SQLiteStore

    def initialize: (SQLiteStore sqlite_store) -> void
    def write: (event: event, destination_name: String, ?error: Exception?, ?retry_count: Integer) -> Integer
    def pending: (?limit: Integer) -> Array[row]
    def count: (?status: String?) -> Integer
    def resolve: (Integer id) -> void
    def ignore: (Integer id) -> void

    private

    def database: () -> untyped
    def update_status: (Integer id, String status) -> untyped
  end

  class DeliveryWorker
    DEFAULT_SOURCE: String

    attr_reader sink: _Sink
    attr_reader checkpoint_store: CheckpointStore
    attr_reader dead_letter_store: DeadLetterStore
    attr_reader retry_schedule: Array[Integer]
    attr_reader max_attempts: Integer
    attr_reader sleeper: _Sleeper
    attr_reader source_name: String
    attr_reader slot_name: String
    attr_reader publication_name: String

    def initialize: (sink: _Sink, checkpoint_store: CheckpointStore, dead_letter_store: DeadLetterStore, source_name: String, slot_name: String, publication_name: String, max_attempts: Integer, retry_schedule: Array[Integer], ?sleeper: _Sleeper) -> void
    def self.from_config: (Configuration config, sink: _Sink, checkpoint_store: CheckpointStore, dead_letter_store: DeadLetterStore, ?sleeper: _Sleeper) -> DeliveryWorker
    def deliver: (event event) -> Hash[Symbol, untyped]

    private

    def checkpoint: (event event) -> row?
    def dead_letter: (event event, DeliveryError error, Integer attempts) -> Hash[Symbol, untyped]
    def wait_before_retry: (Integer attempts) -> untyped
  end

  class EventSerializer
    DEFAULT_SOURCE: String

    def self.call: (event event) -> Hash[String, untyped]
    def initialize: (event event) -> void
    def call: () -> Hash[String, untyped]
    def to_json: (*untyped args) -> String

    private

    def stringify_keys: (untyped hash) -> Hash[String, untyped]
    def normalize_operation: (untyped operation) -> String
    def occurred_at: (Hash[String, untyped] event_hash) -> untyped
    def event_data: (Hash[String, untyped] event_hash) -> untyped
  end

  class PgoutputSource
    attr_reader config: Configuration
    attr_reader runner: untyped
    attr_reader parser: untyped
    attr_reader decoder: untyped
    attr_reader source_adapter: untyped

    def initialize: (Configuration config, ?runner: untyped, ?parser: untyped, ?decoder: untyped, ?source_adapter: untyped) -> void
    def each: () { (untyped work) -> untyped } -> untyped
          | () -> Enumerator[untyped, untyped]

    private

    def normalized_items: (String payload, untyped metadata) -> Array[untyped]
    def parsed_payload: (String payload) -> untyped
    def invoke_source_adapter: (untyped decoded, untyped metadata) -> untyped
    def invoke_component: (untyped component, *untyped args) -> untyped
    def effective_runner: () -> _Runner
    def effective_parser: () -> untyped
    def effective_decoder: () -> untyped
    def effective_source_adapter: () -> untyped
    def build_runner: () -> _Runner
    def build_parser: () -> untyped
    def build_decoder: () -> untyped
    def build_source_adapter: () -> untyped
    def database_url: () -> String
    def require_optional!: (String feature, String gem_name) -> void
    def require_any!: (Array[String] features, String gem_name) -> bool
    def constant_or_nil: (String name) -> untyped
  end

  class ReplicationConsumer
    attr_reader config: Configuration
    attr_reader source: _EventSource?
    attr_reader adapter: _Adapter?

    def initialize: (Configuration config, ?source: _EventSource?, ?adapter: _Adapter?) -> void
    def slot: () -> String
    def publication: () -> String
    def start: () { (untyped event) -> untyped } -> Integer
             | () -> Enumerator[untyped, Integer]

    private

    def each_event: () { (untyped event) -> untyped } -> untyped
    def effective_source: () -> _EventSource
    def normalize: (untyped raw_work) -> Array[untyped]
    def flatten_cdc_work: (untyped work) -> Array[untyped]
    def transaction_envelope?: (untyped work) -> bool
  end

  class SQLiteStore
    DEFAULT_DB_PATH: String
    MIGRATION_DIR: String
    BOOTSTRAP_FILE: String
    BOOTSTRAP_VERSION: String
    MIGRATIONS_TABLE: String

    attr_reader path: String

    def self.connect: (?String path) -> SQLiteStore
    def initialize: (?String path) -> void
    def connect: () -> SQLiteStore
    def database: () -> untyped
    def bootstrap!: () -> SQLiteStore
    def migrate!: (String sql_file) -> SQLiteStore
    def bootstrapped?: () -> bool
    def table_exists?: (String table_name) -> bool
    def version_exists?: (String version_name) -> bool
    def tables: () -> Array[String]

    private

    def apply_migration!: (String sql_file, String version_name) -> untyped
    def execute_pragma: (String name, String | Integer value) -> untyped
  end

  class Status
    attr_reader config: Configuration
    attr_reader sqlite_store: SQLiteStore?

    def self.call: (Configuration config, ?sqlite_store: SQLiteStore?) -> void
    def initialize: (Configuration config, ?sqlite_store: SQLiteStore?) -> void
    def call: () -> void

    private

    def sqlite_path: () -> String
    def print_store_state: () -> void
  end

  class WebhookSink
    SUCCESS_RANGE: Range[Integer]

    attr_reader name: String
    attr_reader url: URI::Generic
    attr_reader timeout_seconds: Integer

    def initialize: (name: String, url: String, ?timeout_seconds: Integer) -> void
    def self.from_config: (Configuration config) -> WebhookSink
    def deliver: (event event) -> Hash[Symbol, untyped]

    private

    def perform_request: (Hash[String, untyped] payload) -> untyped
    def build_request: (Hash[String, untyped] payload) -> Net::HTTP::Post
    def delivery_result: (Hash[String, untyped] payload, untyped response) -> Hash[Symbol, untyped]
  end
end
