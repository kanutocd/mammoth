# Override this when testing an unreleased or locally built Mammoth image.
MAMMOTH_IMAGE=ghcr.io/kanutocd/mammoth:v1.1.0

# Bound WAL retained by an unavailable logical-replication consumer.
# Increase this from the quickstart's 1GB default for your WAL rate and recovery budget.
POSTGRES_MAX_SLOT_WAL_KEEP_SIZE=1GB
